#!/usr/bin/env bash
# 描述： 卸载软件包TUI (Pacman/AUR + Flatpak)
# Description: Remove pkgs TUI (Pacman/AUR + Flatpak)
# ==============================================================================
set -euo pipefail

SCRIPT_PATH=$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")
export SHELL=$(grep -m 1 -E '^/.*/bash$' /etc/shells || echo "/bin/bash")

ORIGINAL_LANG="${LC_ALL:-${LC_MESSAGES:-${LANG:-C}}}"
export LC_ALL=C

# --- 1. 隐藏的内部调用：用于生成/刷新数据 ---
# 输出格式: <可见列(带颜色)>\t<src>\t<pkg>
# src 取值: pacman / aur / flatpak
# 其中 flatpak 的 pkg 字段为 app_id
if [[ "${1:-}" == "--generate-data" ]]; then
    AWK_CMD_PACMAN='
        NR==FNR {
            if (!($2 in repo)) { repo[$2] = $1 }
            next
        }
        {
            pkg_name = $1; pkg_ver = $2
            rname = (pkg_name in repo) ? repo[pkg_name] : "aur"
            color = (pkg_name in repo) ? cb : cp
            visible = sprintf("%s%s%s", color, rname, r)
            for(i=length(rname); i<16; i++) visible = visible " "
            visible = sprintf("%s %-35s %-22s", visible, pkg_name, pkg_ver)
            src = (pkg_name in repo) ? "pacman" : "aur"
            printf "%s\t%s\t%s\n", visible, src, pkg_name
        }
    '

    AWK_CMD_FLATPAK='
        {
            if (NF < 3) next
            app_id = $1; origin = $2
            $1=""; $2=""; name=$0
            sub(/^[ \t]+/, "", name); sub(/[ \t]+$/, "", name)
            visible = sprintf("%s%s%s", cc, origin, r)
            for(i=length(origin); i<16; i++) visible = visible " "
            visible = sprintf("%s %-35s %-22s", visible, name, app_id)
            printf "%s\t%s\t%s\n", visible, "flatpak", app_id
        }
    '

    # 生成 Pacman/AUR 数据
    awk -v cb='\033[34m' -v cp='\033[35m' -v r='\033[0m' \
        "$AWK_CMD_PACMAN" <(pacman --color=never -Sl 2>/dev/null || true) <(pacman --color=never -Q)

    # 生成 Flatpak 数据
    if command -v flatpak >/dev/null 2>&1; then
        flatpak list --app --columns=application,origin,name 2>/dev/null | \
        awk -v cc='\033[36m' -v r='\033[0m' "$AWK_CMD_FLATPAK" || true
    fi
    exit 0
fi

# --- 2. 环境与多语言字典配置 ---
SHOW_HELP=false
FZF_EXACT=false
QUERY_ARGS=()

declare -A MSG
if [[ "$ORIGINAL_LANG" == *"zh_CN"* ]]; then
    MSG[DESC]="统一模糊搜索并卸载系统软件包 (支持 Pacman/AUR 与 Flatpak)。"
    MSG[OPTS]="选项："
    MSG[OPT_HELP]="  --help, -h    显示此帮助信息并退出"
    MSG[OPT_EXACT]="  --exact, -e   关闭模糊匹配，使用精确匹配模式"
    MSG[FEAT]="功能特性："
    MSG[FEAT_1]="- 大一统架构：同屏混合显示并多选 Native 包与 Flatpak 应用"
    MSG[FEAT_2]="- 彻底与安全：Pacman 递归删除配置 (-Rns)，Flatpak 原生防误删保护"
    MSG[FEAT_3]="- 视觉标识：蓝色(官方源) | 紫色(AUR) | 青色(Flatpak)"
    MSG[EX]="示例："
    MSG[ERR_FZF]="错误：未找到 fzf，请先安装。"
    MSG[ERR_HELPER]="错误：未找到 paru 或 yay，请至少安装其中一个作为 AUR 助手。"
    MSG[REMOVING_PAC]=">> 准备卸载 (Pacman/AUR)："
    MSG[REMOVING_FPK]=">> 准备卸载 (Flatpak)："
    MSG[HEADER]="Tab:多选 | Enter:卸载 | Ctrl+R:刷新 | Ctrl+E:精确/模糊 | Esc:退出"
else
    MSG[DESC]="Unified fuzzy search & remove for system packages (Pacman/AUR & Flatpak)."
    MSG[OPTS]="Options:"
    MSG[OPT_HELP]="  --help, -h    Show this help and exit"
    MSG[OPT_EXACT]="  --exact, -e   Disable fuzzy matching and use exact matching mode"
    MSG[FEAT]="Features:"
    MSG[FEAT_1]="- Unified UI: Mix, multi-select and remove Native & Flatpak apps together"
    MSG[FEAT_2]="- Safe & Clean: Pacman recursive remove (-Rns), Flatpak native protection"
    MSG[FEAT_3]="- Visuals: Blue(Repo) | Purple(AUR) | Cyan(Flatpak)"
    MSG[EX]="Example:"
    MSG[ERR_FZF]="Error: fzf not found."
    MSG[ERR_HELPER]="Error: Neither paru nor yay found. Please install an AUR helper."
    MSG[REMOVING_PAC]=">> Preparing to remove (Pacman/AUR):"
    MSG[REMOVING_FPK]=">> Preparing to remove (Flatpak):"
    MSG[HEADER]="Tab:Multi-Select | Enter:Remove | Ctrl+R:Reload | Ctrl+E:Exact/Fuzzy | Esc:Exit"
fi

# --- 3. 参数解析 ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) SHOW_HELP=true; shift ;;
        --exact|-e) FZF_EXACT=true; shift ;;
        *) QUERY_ARGS+=("$1"); shift ;;
    esac
done

# --- 4. 核心依赖检查与动态 Helper 探测 ---
command -v fzf >/dev/null 2>&1 || { echo "${MSG[ERR_FZF]}" >&2; exit 1; }

AUR_HELPER=""
if command -v paru >/dev/null 2>&1; then
    AUR_HELPER="paru"
elif command -v yay >/dev/null 2>&1; then
    AUR_HELPER="yay"
else
    echo "${MSG[ERR_HELPER]}" >&2
    exit 1
fi

HAS_FLATPAK=false
if command -v flatpak >/dev/null 2>&1; then
    HAS_FLATPAK=true
fi

# --- 5. 帮助信息拦截 ---
if [ "$SHOW_HELP" = true ]; then
    cat <<EOF
Usage: ${0##*/} [options] [query]

${MSG[OPTS]}
${MSG[OPT_HELP]}
${MSG[OPT_EXACT]}

Description:
  ${MSG[DESC]}

${MSG[FEAT]}
  ${MSG[FEAT_1]}
  ${MSG[FEAT_2]}
  ${MSG[FEAT_3]}

${MSG[EX]}
  ${0##*/} firefox        # 搜索并卸载 'firefox' (无缝跨越两端)
  ${0##*/} -e firefox     # 精确匹配
  ${0##*/}                # 列出所有已安装的包
EOF
    exit 0
fi

# --- 6. 文件安全设置 ---
TMP_DIR=$(mktemp -d -t unified_pacr.XXXXXX)
TARGET_FILE="${TMP_DIR}/target"
LIST_FILE="${TMP_DIR}/list"

cleanup() { rm -rf "$TMP_DIR"; }
trap cleanup EXIT INT TERM

# --- 7. 交互式 FZF 渲染与智能预览 ---
PREVIEW_CMD="export LC_ALL=\"$ORIGINAL_LANG\"; line={}; src=\$(printf '%s' \"\$line\" | awk -F'\t' '{print \$2}'); pkg=\$(printf '%s' \"\$line\" | awk -F'\t' '{print \$3}'); if [[ \"\$src\" == \"flatpak\" ]]; then flatpak info \"\$pkg\" | awk '{ sub(/^[ \\t]*[^:：]*[:：]/, \"\\033[36m&\\033[0m\"); print }'; else $AUR_HELPER -Qi \"\$pkg\" | awk -v c=\"\$(printf '\\033[1;36m')\" -v r=\"\$(printf '\\033[0m')\" '{ if (match(\$0, /^[ \\t]*[^:：]+[:：]/)) { key=substr(\$0,1,RLENGTH); val=substr(\$0,RLENGTH+1); gsub(/\\033\\[[0-9;]*[a-zA-Z]/, \"\", key); print c key r val } else print \$0 }'; fi"

COLOR_YELLOW=$'\033[33m'
COLOR_CYAN=$'\033[36m'
COLOR_RESET=$'\033[0m'
FZF_HEADER="${MSG[HEADER]} | ${COLOR_YELLOW}${AUR_HELPER}${COLOR_RESET}"
if [ "$HAS_FLATPAK" = true ]; then
    FZF_HEADER+=" & ${COLOR_CYAN}Flatpak${COLOR_RESET}"
fi

"$SCRIPT_PATH" --generate-data > "$LIST_FILE"
QUERY_TEXT="${QUERY_ARGS[*]:-}"

while true; do
    FZF_MATCH_OPTIONS=()
    if [[ "$FZF_EXACT" == true ]]; then
        FZF_MATCH_OPTIONS+=(--exact)
        CURRENT_HEADER="${FZF_HEADER} | Mode: Exact"
    else
        CURRENT_HEADER="${FZF_HEADER} | Mode: Fuzzy"
    fi

    set +e
    fzf --multi --ansi \
        "${FZF_MATCH_OPTIONS[@]}" \
        --delimiter=$'\t' \
        --with-nth=1 \
        --expect=ctrl-e,ctrl-r \
        --print-query \
        --preview "$PREVIEW_CMD" \
        --preview-window=down:55%:wrap \
        --height=95% --layout=reverse --border \
        --bind "alt-j:last,alt-k:first" \
        --tiebreak=index \
        --header "$CURRENT_HEADER" \
        --query "$QUERY_TEXT" \
        < "$LIST_FILE" \
        > "$TARGET_FILE"
    FZF_EXIT=$?
    set -e

    FZF_KEY=""
    if [[ -s "$TARGET_FILE" ]]; then
        FZF_LINE1="$(sed -n '1p' "$TARGET_FILE")"
        FZF_LINE2="$(sed -n '2p' "$TARGET_FILE")"
        if [[ "$FZF_LINE1" == "ctrl-e" || "$FZF_LINE1" == "ctrl-r" || "$FZF_LINE2" == "ctrl-e" || "$FZF_LINE2" == "ctrl-r" ]]; then
            if [[ "$FZF_LINE1" == "ctrl-e" || "$FZF_LINE1" == "ctrl-r" ]]; then
                FZF_KEY="$FZF_LINE1"
                QUERY_TEXT="$FZF_LINE2"
            else
                FZF_KEY="$FZF_LINE2"
                QUERY_TEXT="$FZF_LINE1"
            fi
        else
            QUERY_TEXT="$FZF_LINE1"
        fi
    fi

    if [[ $FZF_EXIT -eq 0 && "$FZF_KEY" == "ctrl-e" ]]; then
        if [[ "$FZF_EXACT" == true ]]; then
            FZF_EXACT=false
        else
            FZF_EXACT=true
        fi
        continue
    fi

    if [[ $FZF_EXIT -eq 0 && "$FZF_KEY" == "ctrl-r" ]]; then
        "$SCRIPT_PATH" --generate-data > "$LIST_FILE"
        continue
    fi

    break
done

# --- 8. 执行卸载逻辑 (分发处理) ---
if [[ $FZF_EXIT -eq 0 ]] && [[ -s "$TARGET_FILE" ]]; then
    mapfile -t SELECTED_LINES < <(awk -F'\t' 'NF >= 3 { print }' "$TARGET_FILE")
    PAC_PKGS=()
    FPK_PKGS=()

    for line in "${SELECTED_LINES[@]}"; do
        src=$(printf '%s\n' "$line" | awk -F'\t' '{print $2}')
        pkg=$(printf '%s\n' "$line" | awk -F'\t' '{print $3}')
        [[ -z "$src" || -z "$pkg" ]] && continue
        if [[ "$src" == "flatpak" ]]; then
            FPK_PKGS+=("$pkg")
        else
            PAC_PKGS+=("$pkg")
        fi
    done

    if [[ ${#PAC_PKGS[@]} -gt 0 ]]; then
        echo -e "\n\033[34m${MSG[REMOVING_PAC]}\033[0m"
        echo "${PAC_PKGS[*]}"
        echo "----------------------------------------"
        "$AUR_HELPER" -Rns "${PAC_PKGS[@]}"
    fi

    if [[ ${#FPK_PKGS[@]} -gt 0 ]]; then
        echo -e "\n\033[36m${MSG[REMOVING_FPK]}\033[0m"
        echo "${FPK_PKGS[*]}"
        echo "----------------------------------------"
        flatpak uninstall "${FPK_PKGS[@]}"
    fi
fi
