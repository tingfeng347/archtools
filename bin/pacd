#!/usr/bin/env bash
# 描述： 降级软件TUI (Pacman/AUR)
# Description: Downgrade pkgs TUI (Pacman/AUR)
# Features:
#   1. 模糊搜索已安装软件包并传递给 downgrade 进行版本回退
#   2. 自动检测系统依赖 (fzf, downgrade, paru/yay)
#   3. 动态追溯并显示包的真实来源 (core/extra/aur 等)
#   4. 严格执行前置高危操作安全警告，防止破坏系统依赖链
#   5. 实时下半屏预览软件包详细信息
#   6. Ctrl+E 切换精确/模糊匹配
# ==============================================================================

set -euo pipefail

SCRIPT_PATH=$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")

# --- 1. 环境与基础配置 ---
ORIGINAL_LANG="${LC_ALL:-${LC_MESSAGES:-${LANG:-C}}}"
SHOW_HELP=false
FZF_EXACT=false
QUERY_ARGS=()

export LC_ALL=C

# --- 2. 隐藏的内部调用：生成已安装包列表 ---
# 输出格式: <可见列(带颜色)>\t<src>\t<pkg>
if [[ "${1:-}" == "--generate-data" ]]; then
    AWK_CMD='
        NR==FNR {
            if (!($2 in repo)) { repo[$2] = $1 }
            next
        }
        {
            pkg_name = $1
            pkg_ver = $2
            if (pkg_name in repo) {
                rname = repo[pkg_name]
                visible = sprintf("%s%s%s", cb, rname, r)
                for(i=length(rname); i<16; i++) visible = visible " "
                visible = sprintf("%s %-35s %-22s", visible, pkg_name, pkg_ver)
                printf "%s\t%s\t%s\n", visible, "pacman", pkg_name
            } else {
                rname = "aur"
                visible = sprintf("%s%s%s", cp, rname, r)
                for(i=length(rname); i<16; i++) visible = visible " "
                visible = sprintf("%s %-35s %-22s", visible, pkg_name, pkg_ver)
                printf "%s\t%s\t%s\n", visible, "aur", pkg_name
            }
        }
    '
    pacman --color=never -Sl > "${TMP_DIR_PACD:-/tmp}/pacd_sync_db.txt" 2>/dev/null || true
    pacman --color=never -Q 2>/dev/null | \
        awk -v cb='\033[34m' -v cp='\033[35m' -v r='\033[0m' \
            "$AWK_CMD" "${TMP_DIR_PACD:-/tmp}/pacd_sync_db.txt" -
    exit 0
fi

# --- 3. 参数解析 ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) SHOW_HELP=true; shift ;;
        --exact|-e) FZF_EXACT=true; shift ;;
        *) QUERY_ARGS+=("$1"); shift ;;
    esac
done

# --- 4. 本地化多语言字典 ---
declare -A MSG
if [[ "$ORIGINAL_LANG" == *"zh_CN"* ]]; then
    MSG[DESC]="模糊搜索已安装的软件包并进行版本降级。"
    MSG[OPTS]="选项："
    MSG[OPT_HELP]="  --help, -h    显示此帮助信息并退出"
    MSG[OPT_EXACT]="  --exact, -e   关闭模糊匹配，使用精确匹配模式"
    MSG[FEAT]="功能特性："
    MSG[FEAT_1]="- 历史回溯：集成 downgrade，支持从本地缓存或 A.L.A 降级"
    MSG[FEAT_2]="- 精准追溯：动态比对显示包的真实来源 (core/extra/aur 等)"
    MSG[FEAT_3]="- 依赖安全：移交 pacman 进行底层依赖拦截，并提供强警告"
    MSG[EX]="示例："
    MSG[ERR_DEPS]="\033[1;31m[错误] 缺少核心依赖程序！\033[0m\n未找到命令: \033[1;33m%s\033[0m\n参考安装: \033[32msudo pacman -S %s\033[0m\n"
    MSG[ERR_HELPER]="\033[1;31m[错误] 未找到 AUR 助手！\033[0m\n请至少安装 \033[32mparu\033[0m 或 \033[32myay\033[0m 以支持包信息预览。\n"
    MSG[ERR_DOWNGRADE]="\033[1;31m[错误] 未找到 downgrade 工具！\033[0m\n此脚本强依赖该工具执行版本回退操作。\n参考安装: \033[32m%s -S downgrade\033[0m\n"
    MSG[DOWNGRADING]=">> 准备降级："
    MSG[WARN_DEP]="[依赖危险警告] 降级核心库(如 glibc, mesa, python 等)极易导致系统崩溃！"
    MSG[HEADER]="Tab:多选 | Enter:降级 | Ctrl+R:刷新 | Ctrl+E:精确/模糊 | Esc:退出"
else
    MSG[DESC]="Fuzzy search and downgrade installed packages."
    MSG[OPTS]="Options:"
    MSG[OPT_HELP]="  --help, -h    Show this help and exit"
    MSG[OPT_EXACT]="  --exact, -e   Disable fuzzy matching and use exact matching mode"
    MSG[FEAT]="Features:"
    MSG[FEAT_1]="- History: Integrates with downgrade tool (Local Cache / A.L.A)"
    MSG[FEAT_2]="- Exact Origin: Dynamically maps package to real repo"
    MSG[FEAT_3]="- Dependency Safety: Relies on pacman strictly, with pre-execution warnings"
    MSG[EX]="Example:"
    MSG[ERR_DEPS]="\033[1;31m[Error] Missing core dependencies!\033[0m\nCommands not found: \033[1;33m%s\033[0m\nInstall via: \033[32msudo pacman -S %s\033[0m\n"
    MSG[ERR_HELPER]="\033[1;31m[Error] AUR helper not found!\033[0m\nPlease install \033[32mparu\033[0m or \033[32myay\033[0m to support package previews.\n"
    MSG[ERR_DOWNGRADE]="\033[1;31m[Error] downgrade tool not found!\033[0m\nThis script strictly requires 'downgrade' to operate.\nInstall via: \033[32m%s -S downgrade\033[0m\n"
    MSG[DOWNGRADING]=">> Preparing to downgrade:"
    MSG[WARN_DEP]="[DANGER] Downgrading core libs can break your system!"
    MSG[HEADER]="Tab:Multi-Select | Enter:Downgrade | Ctrl+R:Reload | Ctrl+E:Exact/Fuzzy | Esc:Exit"
fi

# --- 5. 帮助信息拦截 ---
if [ "$SHOW_HELP" = true ]; then
    cat <<EOF
Usage: ${0##*/} [options] [query]

${MSG[OPTS]}
${MSG[OPT_HELP]}
${MSG[OPT_EXACT]}

Description:
  ${MSG[DESC]}

${MSG[FEAT]}
  ${MSG[FEAT_1]}
  ${MSG[FEAT_2]}
  ${MSG[FEAT_3]}

${MSG[EX]}
  ${0##*/} linux        # 搜索并降级 'linux' 内核
  ${0##*/} -e linux     # 精确匹配
  ${0##*/}              # 列出所有已安装的包
EOF
    exit 0
fi

# --- 6. 核心依赖检查与动态 Helper 探测 ---
AUR_HELPER=""
if command -v paru >/dev/null 2>&1; then
    AUR_HELPER="paru"
elif command -v yay >/dev/null 2>&1; then
    AUR_HELPER="yay"
fi

check_dependencies() {
    local missing_deps=()
    for cmd in fzf awk pacman; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing_deps+=("$cmd")
        fi
    done

    if [[ ${#missing_deps[@]} -gt 0 ]]; then
        printf "${MSG[ERR_DEPS]}" "${missing_deps[*]}" "${missing_deps[*]}" >&2
        exit 1
    fi

    if [[ -z "$AUR_HELPER" ]]; then
        echo -e "${MSG[ERR_HELPER]}" >&2
        exit 1
    fi

    if ! command -v downgrade >/dev/null 2>&1; then
        printf "${MSG[ERR_DOWNGRADE]}" "$AUR_HELPER" >&2
        exit 1
    fi
}

check_dependencies

# --- 7. 文件安全设置 ---
TMP_DIR=$(mktemp -d -t pacd_fzf.XXXXXX)
TARGET_FILE="${TMP_DIR}/target"
LIST_FILE="${TMP_DIR}/list"
export TMP_DIR_PACD="$TMP_DIR"

PREVIEW_CMD="export LC_ALL=\"$ORIGINAL_LANG\"; line={}; pkg=\$(printf '%s' \"\$line\" | awk -F'\t' '{print \$3}'); $AUR_HELPER -Qi \"\$pkg\" | awk -v c=\"\$(printf '\\033[1;36m')\" -v r=\"\$(printf '\\033[0m')\" '{ if (match(\$0, /^[ \\t]*[^:：]+[:：]/)) { key=substr(\$0,1,RLENGTH); val=substr(\$0,RLENGTH+1); gsub(/\\033\\[[0-9;]*[a-zA-Z]/, \"\", key); print c key r val } else print \$0 }'"

cleanup() {
    rm -rf "$TMP_DIR"
}
trap cleanup EXIT INT TERM

# --- 8. 数据生成器 ---
"$SCRIPT_PATH" --generate-data > "$LIST_FILE" 2>/dev/null

# --- 9. 交互式 FZF 渲染 ---
COLOR_YELLOW=$'\033[33m'
COLOR_RESET=$'\033[0m'
FZF_HEADER="${MSG[HEADER]} | ${COLOR_YELLOW}Using downgrade & ${AUR_HELPER}${COLOR_RESET}"

QUERY_TEXT="${QUERY_ARGS[*]:-}"

while true; do
    FZF_MATCH_OPTIONS=()
    if [[ "$FZF_EXACT" == true ]]; then
        FZF_MATCH_OPTIONS+=(--exact)
        CURRENT_HEADER="${FZF_HEADER} | Mode: Exact"
    else
        CURRENT_HEADER="${FZF_HEADER} | Mode: Fuzzy"
    fi

    set +e
    fzf --multi --ansi \
        "${FZF_MATCH_OPTIONS[@]}" \
        --delimiter=$'\t' \
        --with-nth=1 \
        --expect=ctrl-e,ctrl-r \
        --print-query \
        --preview "$PREVIEW_CMD" \
        --preview-window=down:55%:wrap \
        --height=95% --layout=reverse --border \
        --bind "alt-j:last,alt-k:first" \
        --tiebreak=index \
        --header "$CURRENT_HEADER" \
        --query "$QUERY_TEXT" \
        < "$LIST_FILE" \
        > "$TARGET_FILE"
    FZF_EXIT=$?
    set -e

    FZF_KEY=""
    if [[ -s "$TARGET_FILE" ]]; then
        FZF_LINE1="$(sed -n '1p' "$TARGET_FILE")"
        FZF_LINE2="$(sed -n '2p' "$TARGET_FILE")"
        if [[ "$FZF_LINE1" == "ctrl-e" || "$FZF_LINE1" == "ctrl-r" || "$FZF_LINE2" == "ctrl-e" || "$FZF_LINE2" == "ctrl-r" ]]; then
            if [[ "$FZF_LINE1" == "ctrl-e" || "$FZF_LINE1" == "ctrl-r" ]]; then
                FZF_KEY="$FZF_LINE1"
                QUERY_TEXT="$FZF_LINE2"
            else
                FZF_KEY="$FZF_LINE2"
                QUERY_TEXT="$FZF_LINE1"
            fi
        else
            QUERY_TEXT="$FZF_LINE1"
        fi
    fi

    if [[ $FZF_EXIT -eq 0 && "$FZF_KEY" == "ctrl-e" ]]; then
        if [[ "$FZF_EXACT" == true ]]; then
            FZF_EXACT=false
        else
            FZF_EXACT=true
        fi
        continue
    fi

    if [[ $FZF_EXIT -eq 0 && "$FZF_KEY" == "ctrl-r" ]]; then
        "$SCRIPT_PATH" --generate-data > "$LIST_FILE" 2>/dev/null
        continue
    fi

    break
done

# --- 10. 执行降级 ---
if [[ $FZF_EXIT -eq 0 ]] && [[ -s "$TARGET_FILE" ]]; then
    mapfile -t SELECTED_LINES < <(awk -F'\t' 'NF >= 3 { print }' "$TARGET_FILE")
    PACKAGES=()
    for line in "${SELECTED_LINES[@]}"; do
        pkg=$(printf '%s\n' "$line" | awk -F'\t' '{print $3}')
        [[ -n "$pkg" ]] && PACKAGES+=("$pkg")
    done

    if [[ ${#PACKAGES[@]} -gt 0 ]]; then
        echo -e "\n\033[33m${MSG[DOWNGRADING]}\033[0m ${PACKAGES[*]}"
        echo -e "\033[31;1m${MSG[WARN_DEP]}\033[0m"
        echo "----------------------------------------"

        # downgrade 本身会在执行 pacman -U 时自动请求 sudo 权限
        sudo downgrade "${PACKAGES[@]}"
    fi
fi
