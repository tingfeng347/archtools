    MSG[OPT_REFRESH]="  --refresh, -y 强制拉取并刷新 AUR 软件包本地缓存列表"
    MSG[OPT_CHECK]="  --check, -c   仅审查 AUR 包，不安装"
    MSG[OPT_EXACT]="  --exact, -e   关闭模糊匹配，使用精确匹配模式"
    MSG[OPT_AI_MODEL]="  --ai-model <模型> 指定 opencode 审查模型 (也可用 PAC_OPENCODE_MODEL)"
