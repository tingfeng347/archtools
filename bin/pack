    MSG[INSTALLED]="[已安装]"
    MSG[INSTALLING]=">> 准备安装："
    MSG[HEADER]="Tab:多选 | Enter:安装 | Ctrl+R:强制刷新 | Ctrl+E:精确/模糊 | Esc:退出"
    MSG[HEADER_CHECK]="Tab:多选 | Enter:审查 | Ctrl+R:强制刷新 | Ctrl+E:精确/模糊 | Esc:退出"
    MSG[EXEC]="> 正在执行: "
    MSG[HINT]="如需重试或记录，可复制以下命令："
    MSG[REVIEWING_AUR]=">> 正在审查 AUR 包："
