# --- 4. 帮助信息拦截 ---
if [ "$SHOW_HELP" = true ]; then
    cat <<EOF
Usage: ${0##*/} [options] [query]

${MSG[OPTS]}
${MSG[OPT_HELP]}
${MSG[OPT_REFRESH]}
${MSG[OPT_CHECK]}
${MSG[OPT_EXACT]}
${MSG[OPT_AI_MODEL]}

Description:
  ${MSG[DESC]}

${MSG[FEAT]}
  ${MSG[FEAT_1]}
  ${MSG[FEAT_2]}
  ${MSG[FEAT_3]}
  ${MSG[FEAT_4]}
  ${MSG[FEAT_5]}

${MSG[EX]}
  ${0##*/} firefox        # 搜索 'firefox'
  ${0##*/} -e firefox     # 精确匹配搜索
  ${0##*/} -y             # 强制刷新并列出所有包
EOF
    exit 0
fi

# --- 5. 核心依赖检查与后端探测 ---
command -v fzf >/dev/null 2>&1 || { echo "${MSG[ERR_FZF]}" >&2; exit 1; }

AUR_HELPER=""
PACMAN_AVAILABLE=false
if command -v paru >/dev/null 2>&1; then
    AUR_HELPER="paru"
    PACMAN_AVAILABLE=true
elif command -v yay >/dev/null 2>&1; then
    AUR_HELPER="yay"
    PACMAN_AVAILABLE=true
elif command -v pacman >/dev/null 2>&1; then
    PACMAN_AVAILABLE=true
fi

AUR_AVAILABLE=false
if [[ -n "$AUR_HELPER" ]]; then
    AUR_AVAILABLE=true
fi

FLATPAK_AVAILABLE=false
if command -v flatpak >/dev/null 2>&1; then
    if [[ -n "$(flatpak remotes --columns=name 2>/dev/null)" ]]; then
        FLATPAK_AVAILABLE=true
    fi
fi

if [[ "$PACMAN_AVAILABLE" == false && "$AUR_AVAILABLE" == false && "$FLATPAK_AVAILABLE" == false ]]; then
    echo "${MSG[ERR_NO_BACKEND]}" >&2
    exit 1
fi

# --- 6. 文件安全设置 ---
TMP_DIR=$(mktemp -d -t pack_fzf.XXXXXX)
TARGET_FILE="${TMP_DIR}/target"
LIST_FILE="${TMP_DIR}/list"
INSTALLED_LIST="${TMP_DIR}/installed"
FLATPAK_INSTALLED="${TMP_DIR}/flatpak_installed"
mkdir -p "$CACHE_DIR"

AUR_CACHE="${CACHE_DIR}/aur_packages.gz.txt"
AUR_FILTER='^(mingw-|lib32-|cross-|.*-debug$)'
if [[ "$ORIGINAL_LANG" == *"zh_CN"* ]]; then
    CACHE_LOCALE="zh_CN"
else
    CACHE_LOCALE="en"
fi
PACKAGE_LIST_CACHE="${CACHE_DIR}/package-list-v1-${CACHE_LOCALE}.tsv"

# Preview AWK: 给属性键加粗青色高亮
AWK_PREVIEW='{
    if (match($0, /^[ \t]*[^:：]+[:：]/)) {
        key = substr($0, 1, RLENGTH);
        val = substr($0, RLENGTH + 1);
        gsub(/\033\[[0-9;]*[a-zA-Z]/, "", key);
        print c key r val;
    } else {
        print $0;
    }
}'

SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
AUR_REVIEW_PROMPT=""
for candidate in \
    "/usr/share/archtools/prompts/aur-review.md" \
    "$SCRIPT_DIR/../share/prompts/aur-review.md"
do
    if [[ -f "$candidate" ]]; then
        AUR_REVIEW_PROMPT="$candidate"
        break
    fi
done

# --- AUR review helper functions ---
extract_review_report() {
    local log_file="$1"
    local report_file="$2"
    sed $'s/\033\\[[0-9;]*[a-zA-Z]//g' "$log_file" | awk '
        /<system-reminder>/ { skip = 1; next }
        /<\/system-reminder>/ { skip = 0; next }
        skip { next }
        /^The final line of the response MUST be/ { next }
        /^PAC_DECISION:/ { next }
        /^## PKGBUILD意图/ { capture = 1; report = $0 "\n"; next }
        capture { report = report $0 "\n" }
        END { if (report != "") printf "%s", report }
    ' > "$report_file"
}

is_risky_review() {
    local report_file="$1"
    grep -Fq '审查结果：中风险' "$report_file" || \
    grep -Fq '审查结果：高风险' "$report_file" || \
    grep -Fq '## 🟡' "$report_file" || \
    grep -Fq '## 🔴' "$report_file"
}

review_risk_label() {
    local report_file="$1"
    local decision_file="${2:-}"
    if [[ -n "$decision_file" ]] && sed $'s/\033\\[[0-9;]*[a-zA-Z]//g' "$decision_file" | grep -Eq '^PAC_DECISION:.*"risk"[[:space:]]*:[[:space:]]*"high"'; then
        printf '%s' "${MSG[INSTALL_RISK_HIGH]}"
    elif [[ -n "$decision_file" ]] && sed $'s/\033\\[[0-9;]*[a-zA-Z]//g' "$decision_file" | grep -Eq '^PAC_DECISION:.*"risk"[[:space:]]*:[[:space:]]*"medium"'; then
        printf '%s' "${MSG[INSTALL_RISK_MEDIUM]}"
    elif [[ -n "$decision_file" ]] && sed $'s/\033\\[[0-9;]*[a-zA-Z]//g' "$decision_file" | grep -Eq '^PAC_DECISION:.*"risk"[[:space:]]*:[[:space:]]*"low"'; then
        printf '%s' "${MSG[INSTALL_RISK_LOW]}"
    elif grep -Fq '审查结果：高风险' "$report_file" || grep -Fq '## 🔴' "$report_file"; then
        printf '%s' "${MSG[INSTALL_RISK_HIGH]}"
    elif grep -Fq '审查结果：中风险' "$report_file" || grep -Fq '## 🟡' "$report_file"; then
        printf '%s' "${MSG[INSTALL_RISK_MEDIUM]}"
    else
        printf '%s' "${MSG[INSTALL_RISK_LOW]}"
    fi
}

review_recommends_install() {
    local report_file="$1"
    local decision_file="${2:-}"
    if [[ -n "$decision_file" ]] && sed $'s/\033\\[[0-9;]*[a-zA-Z]//g' "$decision_file" | grep -Eq '^PAC_DECISION:.*"install_default"[[:space:]]*:[[:space:]]*"yes"'; then
        return 0
    fi
    grep -Fq -- '- 建议可继续安装' "$report_file" || \
    grep -Fq -- '- 建议继续安装' "$report_file" || \
    grep -Fq -- '- 建议可继续' "$report_file" || \
    grep -Eiq -- '- .*continue (installing|installation)' "$report_file"
}

review_recommends_cancel() {
    local report_file="$1"
    local decision_file="${2:-}"
    if [[ -n "$decision_file" ]] && sed $'s/\033\\[[0-9;]*[a-zA-Z]//g' "$decision_file" | grep -Eq '^PAC_DECISION:.*"install_default"[[:space:]]*:[[:space:]]*"no"'; then
        return 0
    fi
    grep -Fq -- '- 建议谨慎安装' "$report_file" || \
    grep -Fq -- '- 建议取消安装' "$report_file"
}

aur_build_dir() {
    local pkg="$1"
    if [[ "$AUR_HELPER" == "paru" ]]; then
        printf '%s/paru/clone/.pac-review/%s' "${XDG_CACHE_HOME:-$HOME/.cache}" "$pkg"
    else
        printf '%s/yay/.pac-review/%s' "${XDG_CACHE_HOME:-$HOME/.cache}" "$pkg"
    fi
}

fetch_aur_build_files() {
    local pkg="$1"
    local build_root="$2"
    local pkgbuilds=()
    local pkgbuild
    rm -rf -- "$build_root"
    mkdir -p "$build_root"
    (cd "$build_root" && LC_ALL="$ORIGINAL_LANG" "$AUR_HELPER" --aur --redownload -G "$pkg")
    shopt -s nullglob
    pkgbuilds=("$build_root"/PKGBUILD "$build_root"/*/PKGBUILD)
    shopt -u nullglob
    for pkgbuild in "${pkgbuilds[@]}"; do
        if [[ -f "$pkgbuild" ]]; then
            AUR_BUILD_DIR="$(dirname "$pkgbuild")"
            return 0
        fi
    done
    return 1
}

select_review_model() {
    local selected
    selected=$(opencode models 2>/dev/null | fzf --height=80% --layout=reverse --border \
        --header "${MSG[MODEL_HEADER]}") || return 1
    if [[ -n "$selected" ]]; then
        OPENCODE_MODEL="$selected"
        mkdir -p "$CACHE_DIR"
        printf '%s\n' "$OPENCODE_MODEL" > "$MODEL_CACHE"
        echo -e "\033[36m${MSG[MODEL_SELECTED]}\033[0m $OPENCODE_MODEL"
    fi
}

cleanup() {
    rm -rf "$TMP_DIR"
}
abort() {
    cleanup
    exit 130
}
trap cleanup EXIT
trap abort INT TERM

# --- 7. 快速首屏：先读取持久缓存，完整列表在 fzf 内后台刷新 ---
if [[ -s "$PACKAGE_LIST_CACHE" ]]; then
    cp -- "$PACKAGE_LIST_CACHE" "$LIST_FILE"
    START_RELOAD_ACTION="reload-sync"
else
    : > "$LIST_FILE"
    START_RELOAD_ACTION="reload"
fi

printf -v AUTO_REFRESH_CMD '%q ' bash "$SCRIPT_PATH" --refresh-cache "$FORCE_REFRESH" \
    "$PACKAGE_LIST_CACHE" "$INSTALLED_LIST" "$AUR_CACHE" "$AUR_FILTER" "$FLATPAK_INSTALLED" \
    "${MSG[INSTALLED]}" "$PACMAN_AVAILABLE" "$AUR_AVAILABLE" "$FLATPAK_AVAILABLE" false
AUTO_REFRESH_CMD="${AUTO_REFRESH_CMD% }"

printf -v FORCE_REFRESH_CMD '%q ' bash "$SCRIPT_PATH" --refresh-cache true \
    "$PACKAGE_LIST_CACHE" "$INSTALLED_LIST" "$AUR_CACHE" "$AUR_FILTER" "$FLATPAK_INSTALLED" \
    "${MSG[INSTALLED]}" "$PACMAN_AVAILABLE" "$AUR_AVAILABLE" "$FLATPAK_AVAILABLE" true
FORCE_REFRESH_CMD="${FORCE_REFRESH_CMD% }"

# --- 8. FZF 渲染 (支持 Ctrl+E 切换精确/模糊) ---
COLOR_YELLOW=$'\033[33m'
COLOR_RESET=$'\033[0m'

BACKEND_LABEL=""
[[ "$PACMAN_AVAILABLE" == true ]] && BACKEND_LABEL+="pacman "
[[ "$AUR_AVAILABLE" == true ]] && BACKEND_LABEL+="AUR($AUR_HELPER) "
[[ "$FLATPAK_AVAILABLE" == true ]] && BACKEND_LABEL+="flatpak"

if [[ "$CHECK_ONLY" == true ]]; then
    FZF_HEADER="${MSG[HEADER_CHECK]} | ${COLOR_YELLOW}${BACKEND_LABEL}${COLOR_RESET}"
else
    FZF_HEADER="${MSG[HEADER]} | ${COLOR_YELLOW}${BACKEND_LABEL}${COLOR_RESET}"
fi

PREVIEW_CMD="export LC_ALL=\"$ORIGINAL_LANG\"; line={}; src=\$(printf '%s' \"\$line\" | awk -F'\t' '{print \$2}'); pkg=\$(printf '%s' \"\$line\" | awk -F'\t' '{print \$3}'); if [[ \"\$src\" == flat:* ]]; then remote=\"\${src#flat:}\"; flatpak remote-info \"\$remote\" \"\$pkg\" | awk '{ sub(/^[ \\t]*[^:：]*[:：]/, \"\\033[36m&\\033[0m\"); print }'; elif [[ \"\$src\" == aur && -n \"$AUR_HELPER\" ]]; then $AUR_HELPER --color=always -Si \"\$pkg\" | awk -v c=\"\$(printf '\\033[1;36m')\" -v r=\"\$(printf '\\033[0m')\" '$AWK_PREVIEW'; elif command -v pacman >/dev/null 2>&1; then pacman --color=always -Si \"\$src/\$pkg\" | awk -v c=\"\$(printf '\\033[1;36m')\" -v r=\"\$(printf '\\033[0m')\" '$AWK_PREVIEW'; else echo 'No preview available'; fi"

QUERY_TEXT="${QUERY_ARGS[*]:-}"
FIRST_FZF_RUN=true

while true; do
    FZF_MATCH_OPTIONS=()
    if [[ "$FZF_EXACT" == true ]]; then
        FZF_MATCH_OPTIONS+=(--exact)
        CURRENT_HEADER="${FZF_HEADER} | Mode: Exact"
    else
        CURRENT_HEADER="${FZF_HEADER} | Mode: Fuzzy"
    fi

    FZF_RELOAD_BIND="ctrl-r:reload-sync($FORCE_REFRESH_CMD)"
    if [[ "$FIRST_FZF_RUN" == true ]]; then
        FZF_RELOAD_BIND="start:${START_RELOAD_ACTION}($AUTO_REFRESH_CMD),${FZF_RELOAD_BIND}"
    fi

    set +e
    fzf --multi --ansi \
        "${FZF_MATCH_OPTIONS[@]}" \
        --delimiter=$'\t' \
        --with-nth=1 \
        --expect=ctrl-e \
        --print-query \
        --preview "$PREVIEW_CMD" \
        --preview-window=down:55%:wrap \
        --height=95% --layout=reverse --border \
        --bind "alt-j:last,alt-k:first" \
        --bind "$FZF_RELOAD_BIND" \
        --tiebreak=index \
        --header "$CURRENT_HEADER" \
        --query "$QUERY_TEXT" \
        < "$LIST_FILE" \
        > "$TARGET_FILE"
    FZF_EXIT=$?
    set -e
    FIRST_FZF_RUN=false

    FZF_KEY=""
    if [[ -s "$TARGET_FILE" ]]; then
        FZF_LINE1="$(sed -n '1p' "$TARGET_FILE")"
        FZF_LINE2="$(sed -n '2p' "$TARGET_FILE")"
        if [[ "$FZF_LINE1" == "ctrl-e" || "$FZF_LINE2" == "ctrl-e" ]]; then
            if [[ "$FZF_LINE1" == "ctrl-e" ]]; then
                FZF_KEY="$FZF_LINE1"
                QUERY_TEXT="$FZF_LINE2"
            else
                FZF_KEY="$FZF_LINE2"
                QUERY_TEXT="$FZF_LINE1"
            fi
        else
            QUERY_TEXT="$FZF_LINE1"
        fi
    fi

    if [[ $FZF_EXIT -eq 0 && "$FZF_KEY" == "ctrl-e" ]]; then
        if [[ "$FZF_EXACT" == true ]]; then
            FZF_EXACT=false
        else
            FZF_EXACT=true
        fi
        if [[ -s "$PACKAGE_LIST_CACHE" ]]; then
            cp -- "$PACKAGE_LIST_CACHE" "$LIST_FILE"
        fi
        continue
    fi

    break
done

# --- 9. 执行安装 ---
if [[ $FZF_EXIT -eq 0 ]] && [[ -s "$TARGET_FILE" ]]; then
    mapfile -t SELECTED_LINES < <(awk -F'\t' 'NF >= 3 { print }' "$TARGET_FILE")
    REPO_PACKAGES=()
    AUR_PACKAGES=()
    FLATPAK_PACKAGES=()
    FLATPAK_REMOTES=()

    for line in "${SELECTED_LINES[@]}"; do
        src=$(printf '%s\n' "$line" | awk -F'\t' '{print $2}')
        pkg=$(printf '%s\n' "$line" | awk -F'\t' '{print $3}')
        if [[ -z "$src" || -z "$pkg" ]]; then
            continue
        elif [[ "$src" == flat:* ]]; then
            FLATPAK_REMOTES+=("${src#flat:}")
            FLATPAK_PACKAGES+=("$pkg")
        elif [[ "$src" == "aur" ]]; then
            AUR_PACKAGES+=("$pkg")
        else
            REPO_PACKAGES+=("$src/$pkg")
        fi
    done

    # Install official repo packages
    if [[ ${#REPO_PACKAGES[@]} -gt 0 && "$CHECK_ONLY" == true ]]; then
        echo -e "\033[33m${MSG[CHECK_SKIP_REPO]}\033[0m"
        echo "${REPO_PACKAGES[*]}"
    elif [[ ${#REPO_PACKAGES[@]} -gt 0 ]]; then
        FINAL_CMD="$AUR_HELPER -S ${REPO_PACKAGES[*]}"

        echo -e "\n\033[32m${MSG[INSTALLING]}\033[0m"
        echo "${REPO_PACKAGES[*]}"
        echo "----------------------------------------"
        echo -e "\033[90m${MSG[EXEC]}$FINAL_CMD\033[0m\n"

        LC_ALL="$ORIGINAL_LANG" "$AUR_HELPER" -S "${REPO_PACKAGES[@]}"

        echo "----------------------------------------"
        echo -e "\033[36m${MSG[HINT]}\033[0m"
        echo -e "\033[1;33m$FINAL_CMD\033[0m\n"
    fi

    if [[ ${#AUR_PACKAGES[@]} -gt 0 ]]; then
        AUR_REVIEWED=()
        AUR_UNREVIEWED=()
        if ! command -v opencode >/dev/null 2>&1; then
            if [[ "$CHECK_ONLY" == true ]]; then
                echo -e "\033[31m${MSG[CHECK_NO_OPENCODE]}\033[0m" >&2
            else
                echo -e "\033[33m${MSG[NO_OPENCODE]}\033[0m" >&2
                AUR_UNREVIEWED+=("${AUR_PACKAGES[@]}")
            fi
        elif [[ -z "$AUR_REVIEW_PROMPT" ]]; then
            if [[ "$CHECK_ONLY" == true ]]; then
                echo -e "\033[31m${MSG[CHECK_NO_REVIEW_PROMPT]}\033[0m" >&2
            else
                echo -e "\033[33m${MSG[NO_REVIEW_PROMPT]}\033[0m" >&2
                AUR_UNREVIEWED+=("${AUR_PACKAGES[@]}")
            fi
        else
            for pkg in "${AUR_PACKAGES[@]}"; do
                if [[ "$CHECK_ONLY" != true ]]; then
                    while true; do
                        answer=""
                        echo -e "\n\033[35m╭─ ${MSG[REVIEW_ASK_TITLE]}\033[0m"
                        printf "\033[35m│\033[0m ${MSG[REVIEW_ASK_BODY]}\n" "$pkg"
                        echo -e "\033[35m│\033[0m \033[90m${MSG[REVIEW_ASK_HINT]}\033[0m"
                        printf "\033[35m│\033[0m \033[90m${MSG[REVIEW_MODEL]}\033[0m\n" "$OPENCODE_MODEL"
                        printf "\033[35m╰─\033[0m ${MSG[REVIEW_ASK_PROMPT]}"
                        read -r answer || answer="n"
                        case "${answer:-Y}" in
                            y|Y|yes|YES) break ;;
                            m|M) select_review_model || true ;;
                            *) AUR_UNREVIEWED+=("$pkg"); continue 2 ;;
                        esac
                    done
                fi

                AUR_BUILD_DIR="$(aur_build_dir "$pkg")"
                echo -e "\n\033[35m${MSG[FETCHING_AUR_FILES]}\033[0m $pkg"
                echo "----------------------------------------"
                if ! fetch_aur_build_files "$pkg" "$AUR_BUILD_DIR"; then
                    echo -e "\033[31m${MSG[ERR_REVIEW]}\033[0m $pkg" >&2
                    if [[ "$CHECK_ONLY" == true ]]; then continue; fi
                    answer=""
                    printf "${MSG[REVIEW_FAILED_CONFIRM]}" "$pkg"
                    read -r answer || answer="n"
                    case "$answer" in
                        y|Y|yes|YES) AUR_UNREVIEWED+=("$pkg") ;;
                        *) echo -e "\033[33m${MSG[SKIPPED]}\033[0m $pkg" ;;
                    esac
                    continue
                fi

                echo -e "\n\033[35m${MSG[REVIEWING_AUR]}\033[0m $pkg"
                echo "----------------------------------------"
                REVIEW_STATUS=0
                REVIEW_LOG="${TMP_DIR}/review-${pkg}.log"
                REVIEW_REPORT="${TMP_DIR}/review-${pkg}.report"
                REVIEW_MESSAGE="AUR_HELPER=${AUR_HELPER}
PKG=${pkg}
AUR_BUILD_DIR=${AUR_BUILD_DIR}"
                set +e
                opencode run -m "$OPENCODE_MODEL" \
                    -f "$AUR_REVIEW_PROMPT" \
                    --dir "$AUR_BUILD_DIR" \
                    -- \
                    "$REVIEW_MESSAGE" 2>&1 | tee "$REVIEW_LOG" | awk '
                        BEGIN {
                            gray="\033[90m"; cyan="\033[1;36m"; yellow="\033[1;33m"
                            green="\033[1;32m"; red="\033[1;31m"; reset="\033[0m"; report=0
                        }
                        /<system-reminder>/ { skip=1; next }
                        /<\/system-reminder>/ { skip=0; next }
                        skip { next }
                        /^The final line of the response MUST be/ { next }
                        /^PAC_DECISION:/ { next }
                        /^## PKGBUILD意图/ { report=1 }
                        !report { print gray $0 reset; next }
                        /^## PKGBUILD意图/ { print cyan $0 reset; next }
                        /^## 具体风险/ { print yellow $0 reset; next }
                        /^## 🔴/ { print red $0 reset; next }
                        /^## 🟡/ { print yellow $0 reset; next }
                        /^## 🟢/ { print green $0 reset; next }
                        { print }
                    '
                REVIEW_STATUS=${PIPESTATUS[0]}
                set -e
                if [[ $REVIEW_STATUS -eq 130 ]]; then
                    exit 130
                elif [[ $REVIEW_STATUS -ne 0 ]]; then
                    echo -e "\033[31m${MSG[ERR_REVIEW]}\033[0m $pkg" >&2
                    if [[ "$CHECK_ONLY" == true ]]; then
                        rm -f "$REVIEW_LOG" "$REVIEW_REPORT"; continue
                    fi
                    answer=""
                    printf "${MSG[REVIEW_FAILED_CONFIRM]}" "$pkg"
                    read -r answer || answer="n"
                    case "$answer" in
                        y|Y|yes|YES) AUR_UNREVIEWED+=("$pkg") ;;
                        *) echo -e "\033[33m${MSG[SKIPPED]}\033[0m $pkg" ;;
                    esac
                    rm -f "$REVIEW_LOG" "$REVIEW_REPORT"; continue
                fi

                extract_review_report "$REVIEW_LOG" "$REVIEW_REPORT"
                if [[ ! -s "$REVIEW_REPORT" ]]; then
                    echo -e "\033[31m${MSG[ERR_REVIEW]}\033[0m $pkg" >&2
                    if [[ "$CHECK_ONLY" == true ]]; then
                        rm -f "$REVIEW_LOG" "$REVIEW_REPORT"; continue
                    fi
                    answer=""
                    printf "${MSG[REVIEW_FAILED_CONFIRM]}" "$pkg"
                    read -r answer || answer="n"
                    case "$answer" in
                        y|Y|yes|YES) AUR_UNREVIEWED+=("$pkg") ;;
                        *) echo -e "\033[33m${MSG[SKIPPED]}\033[0m $pkg" ;;
                    esac
                    rm -f "$REVIEW_LOG" "$REVIEW_REPORT"; continue
                fi

                echo -e "\033[90m-----------------------------------\033[0m"
                if [[ "$CHECK_ONLY" == true ]]; then
                    rm -f "$REVIEW_LOG" "$REVIEW_REPORT"; continue
                fi

                answer=""
                if review_recommends_install "$REVIEW_REPORT" "$REVIEW_LOG"; then
                    risk_label=$(review_risk_label "$REVIEW_REPORT" "$REVIEW_LOG")
                    echo -e "\n\033[35m╭─ ${risk_label}\033[0m"
                    echo -e "\033[35m│\033[0m  ${MSG[INSTALL_RISK_HINT]}"
                    printf "\033[35m╰─\033[0m [Y/n] "
                    read -r answer || answer="n"
                    case "${answer:-Y}" in
                        y|Y|yes|YES) AUR_REVIEWED+=("$pkg") ;;
                        *) echo -e "\033[33m${MSG[SKIPPED]}\033[0m $pkg" ;;
                    esac
                    rm -f "$REVIEW_LOG" "$REVIEW_REPORT"; continue
                fi

                if review_recommends_cancel "$REVIEW_REPORT" "$REVIEW_LOG" || is_risky_review "$REVIEW_REPORT"; then
                    risk_label=$(review_risk_label "$REVIEW_REPORT" "$REVIEW_LOG")
                    echo -e "\n\033[35m╭─ ${risk_label}\033[0m"
                    echo -e "\033[35m│\033[0m  ${MSG[INSTALL_RISK_HINT]}"
                    printf "\033[35m╰─\033[0m [y/N] "
                    read -r answer || answer="n"
                    case "$answer" in
                        y|Y|yes|YES) AUR_REVIEWED+=("$pkg") ;;
                        *) echo -e "\033[33m${MSG[SKIPPED]}\033[0m $pkg" ;;
                    esac
                    rm -f "$REVIEW_LOG" "$REVIEW_REPORT"; continue
                fi

                risk_label=$(review_risk_label "$REVIEW_REPORT" "$REVIEW_LOG")
                echo -e "\n\033[35m╭─ ${risk_label}\033[0m"
                echo -e "\033[35m│\033[0m  ${MSG[INSTALL_RISK_HINT]}"
                printf "\033[35m╰─\033[0m [Y/n] "
                read -r answer || answer="n"
                case "${answer:-Y}" in
                    y|Y|yes|YES) AUR_REVIEWED+=("$pkg") ;;
                    *) echo -e "\033[33m${MSG[SKIPPED]}\033[0m $pkg" ;;
                esac
                rm -f "$REVIEW_LOG" "$REVIEW_REPORT"
            done
        fi

        if [[ "$CHECK_ONLY" == true ]]; then
            echo -e "\033[36m${MSG[CHECK_DONE]}\033[0m"
        fi

        # Install reviewed AUR packages
        if [[ ${#AUR_REVIEWED[@]} -gt 0 ]]; then
            AUR_INSTALL_ARGS=(-Sa --noconfirm)
            if [[ "$AUR_HELPER" == "paru" ]]; then
                AUR_INSTALL_ARGS+=(--skipreview)
            fi
            AUR_INSTALL_ARGS+=("${AUR_REVIEWED[@]}")
            FINAL_CMD="$AUR_HELPER ${AUR_INSTALL_ARGS[*]}"
            echo -e "\n\033[32m${MSG[INSTALLING]}\033[0m"
            echo "${AUR_REVIEWED[*]}"
            echo "----------------------------------------"
            echo -e "\033[90m${MSG[EXEC]}$FINAL_CMD\033[0m\n"
            LC_ALL="$ORIGINAL_LANG" "$AUR_HELPER" "${AUR_INSTALL_ARGS[@]}"
            echo "----------------------------------------"
            echo -e "\033[36m${MSG[HINT]}\033[0m"
            echo -e "\033[1;33m$FINAL_CMD\033[0m\n"
        fi

        # Install unreviewed AUR packages
        if [[ ${#AUR_UNREVIEWED[@]} -gt 0 ]]; then
            AUR_INSTALL_ARGS=(-Sa)
            if [[ "$AUR_HELPER" == "paru" ]]; then
                AUR_INSTALL_ARGS+=(--skipreview)
            fi
            AUR_INSTALL_ARGS+=("${AUR_UNREVIEWED[@]}")
            FINAL_CMD="$AUR_HELPER ${AUR_INSTALL_ARGS[*]}"
            echo -e "\n\033[32m${MSG[INSTALLING]}\033[0m"
            echo "${AUR_UNREVIEWED[*]}"
            echo "----------------------------------------"
            echo -e "\033[90m${MSG[EXEC]}$FINAL_CMD\033[0m\n"
            LC_ALL="$ORIGINAL_LANG" "$AUR_HELPER" "${AUR_INSTALL_ARGS[@]}"
            echo "----------------------------------------"
            echo -e "\033[36m${MSG[HINT]}\033[0m"
            echo -e "\033[1;33m$FINAL_CMD\033[0m\n"
        fi
    fi

    # Flatpak packages (direct install, no review)
    if [[ ${#FLATPAK_PACKAGES[@]} -gt 0 ]]; then
        if [[ "$CHECK_ONLY" == true ]]; then
            echo -e "\033[33m${MSG[CHECK_SKIP_REPO]}\033[0m"
            echo "flatpak: ${FLATPAK_PACKAGES[*]}"
        else
            FLATPAK_ARGS=()
            for i in "${!FLATPAK_PACKAGES[@]}"; do
                FLATPAK_ARGS+=("${FLATPAK_REMOTES[$i]}//${FLATPAK_PACKAGES[$i]}")
            done
            FINAL_CMD="flatpak install ${FLATPAK_ARGS[*]}"
            echo -e "\n\033[32m${MSG[INSTALLING]}\033[0m"
            echo "${FLATPAK_ARGS[*]}"
            echo "----------------------------------------"
            echo -e "\033[90m${MSG[EXEC]}$FINAL_CMD\033[0m\n"
            LC_ALL="$ORIGINAL_LANG" flatpak install "${FLATPAK_ARGS[@]}"
            echo "----------------------------------------"
            echo -e "\033[36m${MSG[HINT]}\033[0m"
            echo -e "\033[1;33m$FINAL_CMD\033[0m\n"
        fi
    fi
fi
