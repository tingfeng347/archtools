    MSG[MODEL_SELECTED]="Selected review model:"
    MSG[REVIEW_ASK_PROMPT]="Run review? [Y/n/m] "
    MSG[REVIEW_CONFIRM_SAFE]="Read the review above. Continue installing %s? [Y/n] "
    MSG[REVIEW_CONFIRM_RISKY]="Read the review above. Continue installing %s? [y/N] "
    MSG[INSTALL_RISK_LOW]="🟢Low Risk"
    MSG[INSTALL_RISK_MEDIUM]="🟡Medium Risk"
    MSG[INSTALL_RISK_HIGH]="🔴High Risk"
    MSG[INSTALL_RISK_HINT]="Read the review report before deciding whether to continue"
    MSG[SKIPPED]="Skipped install:"
    MSG[NO_OPENCODE]="opencode not found; skipping AI review and continuing normal AUR install."
