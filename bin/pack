#!/usr/bin/env bash
# 描述： 全能包管理TUI (Pacman + AUR + Flatpak)
# Description: All-in-one pkg management TUI (Pacman + AUR + Flatpak)
# ==============================================================================
set -euo pipefail

ORIGINAL_LANG="${LC_ALL:-${LC_MESSAGES:-${LANG:-C}}}"
export LC_ALL=C
export SHELL="${BASH:-/bin/bash}"

SCRIPT_PATH="$(realpath "$0" 2>/dev/null || echo "$0")"

# --- 持久列表缓存刷新器 (由 fzf reload 调用) ---
if [[ "${1:-}" == "--refresh-cache" ]]; then
    REFRESH_FORCE="$2"
    PACKAGE_LIST_CACHE="$3"
    INSTALLED_LIST="$4"
    AUR_CACHE="$5"
    AUR_FILTER="$6"
    FLATPAK_INSTALLED="$7"
    MSG_INSTALLED="$8"
    PACMAN_AVAILABLE="$9"
    AUR_AVAILABLE="${10}"
    FLATPAK_AVAILABLE="${11}"
    FLATPAK_FORCE_REFRESH="${12:-false}"
    PACKAGE_LIST_TMP="${PACKAGE_LIST_CACHE}.tmp.$$"

    cleanup_refresh() {
        rm -f -- "$PACKAGE_LIST_TMP"
    }
    trap cleanup_refresh EXIT INT TERM

    mkdir -p "$(dirname "$PACKAGE_LIST_CACHE")"
    if bash "$SCRIPT_PATH" --generate-list "$REFRESH_FORCE" "$INSTALLED_LIST" "$AUR_CACHE" "$AUR_FILTER" \
        "$FLATPAK_INSTALLED" "$MSG_INSTALLED" "$PACMAN_AVAILABLE" "$AUR_AVAILABLE" \
        "$FLATPAK_AVAILABLE" "$FLATPAK_FORCE_REFRESH" > "$PACKAGE_LIST_TMP" 2>/dev/null
    then
        mv -f -- "$PACKAGE_LIST_TMP" "$PACKAGE_LIST_CACHE"
        cat -- "$PACKAGE_LIST_CACHE"
        exit 0
    fi

    if [[ -s "$PACKAGE_LIST_CACHE" ]]; then
        cat -- "$PACKAGE_LIST_CACHE"
        exit 0
    fi
    exit 1
fi

# --- 0. 内部生成器拦截 (由 fzf reload 触发) ---
if [[ "${1:-}" == "--generate-list" ]]; then
    FORCE_REFRESH="$2"
    INSTALLED_LIST="$3"
    AUR_CACHE="$4"
    AUR_FILTER="$5"
    FLATPAK_INSTALLED="$6"
    MSG_INSTALLED="$7"
    CACHE_TIME=3600
    PACMAN_AVAILABLE="$8"
    AUR_AVAILABLE="$9"
    FLATPAK_AVAILABLE="${10}"
    FLATPAK_FORCE_REFRESH="${11:-false}"

    # 输出格式: <可见列(带颜色)>\t<src>\t<pkg>
    # fzf 用 --with-nth=1 只显示第一列，src/pkg 作为隐藏字段供预览和选中解析使用
    AWK_CMD='
        FNR==NR { installed[$1]=1; next }
        {
            status = ($2 in installed) ? ci " ✔ " label r : ""
            visible = sprintf("%s%s%s", c, $1, r)
            for(i=length($1); i<18; i++) visible = visible " "
            visible = sprintf("%s %-35s %-28s %s", visible, $2, $3, status)
            printf "%s\t%s\t%s\n", visible, $1, $2
        }
    '

    # Pacman installed list
    if [[ "$PACMAN_AVAILABLE" == true ]]; then
        pacman -Qq > "$INSTALLED_LIST" || true
    else
        : > "$INSTALLED_LIST"
    fi

    # Official repos (Pacman)
    if [[ "$PACMAN_AVAILABLE" == true ]]; then
        pacman -Sl 2>/dev/null | awk -v c='\033[34m' -v ci='\033[32m' -v r='\033[0m' \
            -v label="$MSG_INSTALLED" \
            "$AWK_CMD" "$INSTALLED_LIST" -
    fi

    # AUR
    if [[ "$AUR_AVAILABLE" == true ]]; then
        NEED_UPDATE=false
        if [[ "$FORCE_REFRESH" == true ]] || [[ ! -s "$AUR_CACHE" ]]; then
            NEED_UPDATE=true
        elif [[ $(find "$AUR_CACHE" -mmin +$((CACHE_TIME / 60)) 2>/dev/null) ]]; then
            NEED_UPDATE=true
        fi
        if [[ "$NEED_UPDATE" == true ]]; then
            TEMP_AUR="${AUR_CACHE}.tmp.$$"
            if curl -sLf --connect-timeout 2 --max-time 10 --retry 1 \
                https://aur.archlinux.org/packages.gz | zcat > "$TEMP_AUR" 2>/dev/null
            then
                mv "$TEMP_AUR" "$AUR_CACHE"
            else
                rm -f "$TEMP_AUR"
            fi
        fi
        if [[ -s "$AUR_CACHE" ]]; then
            grep -vE "$AUR_FILTER" "$AUR_CACHE" 2>/dev/null | \
            awk '{print "aur", $1, "-"}' | \
            awk -v c='\033[35m' -v ci='\033[32m' -v r='\033[0m' \
                -v label="$MSG_INSTALLED" \
                "$AWK_CMD" "$INSTALLED_LIST" -
        fi
    fi

    # Flatpak
    if [[ "$FLATPAK_AVAILABLE" == true ]]; then
        flatpak list --app --columns=application > "$FLATPAK_INSTALLED" 2>/dev/null || true
        if [[ "$FLATPAK_FORCE_REFRESH" == true ]]; then
            RAW_DATA=$(timeout 10s flatpak remote-ls --app --columns=origin,application,name 2>/dev/null || true)
            if [[ -z "$RAW_DATA" ]]; then
                RAW_DATA=$(flatpak remote-ls --app --cached --columns=origin,application,name 2>/dev/null || true)
            fi
        else
            # 自动刷新只读本地 AppStream 缓存，避免网络阻塞首屏。
            RAW_DATA=$(flatpak remote-ls --app --cached --columns=origin,application,name 2>/dev/null || true)
        fi
        if [[ -n "$RAW_DATA" ]]; then
            echo "$RAW_DATA" | \
            awk -v c='\033[36m' -v ci='\033[32m' -v r='\033[0m' \
                -v label="$MSG_INSTALLED" \
                -v flatpfx="flat:" '
                FILENAME == ARGV[1] { installed[$1]=1; next }
                {
                    origin = flatpfx $1
                    app_id = $2
                    $1=""; $2=""
                    name=$0
                    sub(/^[ \t]+/, "", name)
                    status = (app_id in installed) ? ci " ✔ " label r : ""
                    visible = sprintf("%s%s%s", c, origin, r)
                    for(i=length(origin); i<18; i++) visible = visible " "
                    visible = sprintf("%s %-35s %-28s %s", visible, app_id, name, status)
                    printf "%s\t%s\t%s\n", visible, origin, app_id
                }
            ' "$FLATPAK_INSTALLED" -
        fi
    fi
    exit 0
fi

# --- 1. 环境与基础配置 ---
SHOW_HELP=false
FORCE_REFRESH=false
CHECK_ONLY=false
FZF_EXACT=false
QUERY_ARGS=()
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/pac_tui"
MODEL_CACHE="${CACHE_DIR}/opencode_model"
OPENCODE_MODEL="opencode/deepseek-v4-flash-free"
if [[ -r "$MODEL_CACHE" ]]; then
    read -r CACHED_OPENCODE_MODEL < "$MODEL_CACHE" || true
    if [[ -n "${CACHED_OPENCODE_MODEL:-}" ]]; then
        OPENCODE_MODEL="$CACHED_OPENCODE_MODEL"
    fi
fi
if [[ -n "${PAC_OPENCODE_MODEL:-}" ]]; then
    OPENCODE_MODEL="$PAC_OPENCODE_MODEL"
fi

# --- 2. 参数解析 ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h)
            SHOW_HELP=true
            shift ;;
        --refresh|-y)
            FORCE_REFRESH=true
            shift ;;
        --check|-c)
            CHECK_ONLY=true
            shift ;;
        --exact|-e)
            FZF_EXACT=true
            shift ;;
        --ai-model)
            if [[ -z "${2:-}" ]]; then
                echo "Error: --ai-model requires a model value." >&2
                exit 1
            fi
            OPENCODE_MODEL="${2:-}"
            shift 2 ;;
        *)
            QUERY_ARGS+=("$1")
            shift ;;
    esac
done

# --- 3. 本地化多语言字典 ---
declare -A MSG
if [[ "$ORIGINAL_LANG" == *"zh_CN"* ]]; then
