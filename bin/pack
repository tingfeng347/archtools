    MSG[REVIEW_ASK_HINT]="AUR 包由用户维护，可能存在风险，建议审查；输入 m 设置审查模型。"
    MSG[REVIEW_MODEL]="当前模型：%s"
    MSG[MODEL_HEADER]="选择 opencode 审查模型 | Enter:选择 | Esc:取消"
    MSG[MODEL_SELECTED]="已选择审查模型："
    MSG[REVIEW_ASK_PROMPT]="进行审查? [Y/n/m] "
    MSG[REVIEW_CONFIRM_SAFE]="请阅读上面的审查结果，是否继续安装 %s? [Y/n] "
    MSG[REVIEW_CONFIRM_RISKY]="请阅读上面的审查结果，是否继续安装 %s? [y/N] "
    MSG[INSTALL_RISK_LOW]="🟢低风险"
    MSG[INSTALL_RISK_MEDIUM]="🟡中风险"
    MSG[INSTALL_RISK_HIGH]="🔴高风险"
    MSG[INSTALL_RISK_HINT]="请阅读审查报告后决定是否继续安装"
    MSG[SKIPPED]="已跳过安装："
    MSG[NO_OPENCODE]="未找到 opencode，跳过 AI 审查并继续正常安装 AUR 包。"
    MSG[NO_REVIEW_PROMPT]="未找到 AUR 审查提示词，跳过 AI 审查并继续正常安装 AUR 包。"
    MSG[CHECK_NO_OPENCODE]="未找到 opencode，无法执行 AUR 审查。"
    MSG[CHECK_NO_REVIEW_PROMPT]="未找到 AUR 审查提示词，无法执行 AUR 审查。"
    MSG[CHECK_SKIP_REPO]="仅审查模式会跳过非 AUR 包："
